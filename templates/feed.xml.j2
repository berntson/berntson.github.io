<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
    <title>Daniel Berntson — Blog</title>
    <link href="{{ site_url }}/blog/feed.xml" rel="self"/>
    <link href="{{ site_url }}/blog/"/>
    <updated>{{ updated }}</updated>
    <id>{{ site_url }}/blog/</id>
    <author>
        <name>Daniel Berntson</name>
        <email>daniel@berntson.io</email>
    </author>
    {% for p in posts %}
    <entry>
        <title>{{ p.title }}</title>
        <link href="{{ site_url }}/blog/{{ p.slug }}/"/>
        <id>{{ site_url }}/blog/{{ p.slug }}/</id>
        <updated>{{ p.date.isoformat() }}T00:00:00Z</updated>
        <published>{{ p.date.isoformat() }}T00:00:00Z</published>
        {% if p.description %}<summary>{{ p.description }}</summary>{% endif %}
        <content type="html"><![CDATA[{{ p.body }}]]></content>
    </entry>
    {% endfor %}
</feed>
